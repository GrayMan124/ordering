package ui

import "fmt"

templ MemeTempl(meme_name, meme_text string) {
	<div>
		<h2 class="text-xl font-bold text-slate-100 leading-tight text-center">{ meme_text }</h2>
		<img src={ fmt.Sprintf("/assets/meme/%s.png", meme_name) } class="mx-auto"/>
		<button
			hx-get="/"
			hx-target="#main-area"
			class="mt-8 mx-auto w-fit text-slate-500 hover:text-white text-base transition-colors flex items-center justify-center space-x-2"
		>
			<span>← 戻る (Back)</span>
		</button>
	</div>
}
