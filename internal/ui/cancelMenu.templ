package ui

templ CancelOrder() {
	<div class="flex flex-col items-center text-center py-12 gap-6">
		<div class="hanko" style="border-color:#888780; color:#888780;">取消</div>
		<h2 class="font-mincho text-2xl text-washi tracking-[0.2em]">ご注文をキャンセルしました</h2>
		<img src="/assets/nomore.png" class="w-32 opacity-95"/>
		<button
			hx-get="/"
			hx-target="#main-area"
			class="font-jp text-xs text-washi-dim hover:text-kin tracking-[0.3em] mt-4"
		>
			← 戻る
		</button>
	</div>
}
