package ui

templ OrderSend() {
	<div class="flex flex-col items-center text-center py-12 gap-6">
		<div class="hanko">注文済</div>
		<h2 class="font-mincho text-2xl text-washi tracking-[0.2em]">ご注文ありがとうございます</h2>
		<img src="/assets/arigatou.png" class="w-32 opacity-95"/>
		<button
			hx-get="/"
			hx-target="#main-area"
			class="font-jp text-xs text-washi-dim hover:text-kin tracking-[0.3em] mt-4"
		>
			← 戻る
		</button>
	</div>
}
